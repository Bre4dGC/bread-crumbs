#[ Error and Exception handling (at the design planning stage)

throw <error>   -- throw an error to be caught by a catch block
try <expr>      -- try to execute code that may throw an error
<expr|stmt> catch <error>  -- catch the error and handle it

]#

func divide(a:int, b:int) : int
{
    return if(b == 0) throw "Division by zero error" else a / b
}

try divide(10, 0) catch err {
    println("Caught an error: ", err)
}