#[ Basic function definitions and usage (may change as language design evolves)

        === Function Syntax ===
func <name>(<parameters>) [: <return-type>]
{
    <function body>
}

]#

func add(a : int, b : int) : int
{
    return a + b
}

func main()
{
    var sum : int = add(5, 10)
    println("The sum is: ", sum) # -- Output: The sum is: 15
}