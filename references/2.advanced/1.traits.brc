#[ Traits and Interfaces

trait <trait_name>
{
    <function>
    ...
}

interface <interface_name>
{
    <function>
    ...
}

type <struct_name> : <trait_name>, <interface_name>
{
    ...
}

]#

trait Printable
{
    func print()
    {
        println("This is a printable object.")
    }
}

interface Encodable
{
    func serialize() : str
    func deserialize(str) : void
}

